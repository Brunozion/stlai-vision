# Shared
NODE_ENV=development
APP_BASE_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/stlai_mvp

# Storage
STORAGE_PROVIDER=s3
STORAGE_BUCKET=your-bucket-name
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=replace-me
STORAGE_SECRET_KEY=replace-me
STORAGE_PUBLIC_BASE_URL=https://cdn.example.com

# Auth
JWT_SECRET=replace-me
INTERNAL_API_TOKEN=replace-me

# OpenAI
OPENAI_API_KEY=replace-me
OPENAI_TEXT_MODEL=gpt-5
OPENAI_IMAGE_MODEL=gpt-image-1

# Gemini / alternative providers
GEMINI_API_KEY=replace-me

# Image provider
NANO_BANANA_API_KEY=replace-me

# n8n
N8N_BASE_URL=http://localhost:5678
N8N_INTERNAL_TOKEN=replace-me
N8N_ENABLED=false
N8N_TEXT_WEBHOOK_PATH=/webhook/vision-1-text
N8N_IMAGE_WEBHOOK_PATH=/webhook/vision-1-image

# Frontend public vars
NEXT_PUBLIC_APP_NAME=STLAI MVP
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Development bootstrap
DEV_USER_EMAIL=dev@stlai.local
DEV_USER_NAME=STLAI Dev User
